{
  "manifest_version": 3,
  "name": "Byside",
  "version": "1.0.0",
  "description": "브라우저 옆자리의 AI 일손 — 사이드패널에 말하면 웹 작업을 대신 처리합니다.",
  "minimum_chrome_version": "116",
  "permissions": [
    "tabs",
    "debugger",
    "activeTab",
    "scripting",
    "nativeMessaging",
    "tabGroups",
    "windows",
    "storage",
    "alarms",
    "sidePanel",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Byside"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
