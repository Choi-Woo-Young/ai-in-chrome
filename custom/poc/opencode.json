{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen3:8b",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local stand-in)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder:30b": {
          "name": "Qwen3-Coder 30B (보유)"
        },
        "gpt-oss:20b": {
          "name": "gpt-oss 20B (보유)"
        },
        "freehuntx/qwen3-coder:14b": {
          "name": "Qwen3-Coder 14B (현재 보유, 배선검증용)"
        },
        "qwen3:8b": {
          "name": "Qwen3 8B (현재 보유, 배선검증용)"
        },
        "qwen3-vl:30b-a3b-instruct": {
          "name": "Qwen3-VL 30B-A3B Instruct (비전+도구)",
          "attachment": true,
          "tool_call": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "mcp": {
    "open-claude-in-chrome": {
      "type": "local",
      "command": [
        "/opt/homebrew/bin/node",
        "/Users/wooyoungchoi/StudioProject/niceProjects/ai-in-chrome/host/mcp-server.js"
      ],
      "enabled": true,
      "environment": {
        "OCIC_VL_FORMAT": "openai",
        "OCIC_VL_ENDPOINT": "http://localhost:11434/v1/chat/completions",
        "OCIC_VL_MODEL": "qwen3-vl:30b-a3b-instruct"
      }
    }
  }
}
